# CodeProbe Configuration
# Copy this to .env and fill in your API keys

# Bright Data API Key (for CVE scraping)
BRIGHT_DATA_API_KEY=your_bright_data_key_here

# Daytona API Key (for sandbox provisioning)
DAYTONA_API_KEY=your_daytona_key_here

# Nosana API Key (for LLM patch generation, optional)
NOSANA_API_KEY=your_nosana_key_here

# GitHub Token (for PR comments and auto-fix, optional)
GITHUB_TOKEN=your_github_token_here

# Optional: Debug mode
DEBUG=false
