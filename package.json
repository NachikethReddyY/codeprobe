{
  "name": "codeprobe",
  "version": "1.0.0",
  "description": "Automated vulnerability scanner with exploit verification",
  "type": "module",
  "private": true,
  "bin": {
    "codeprobe": "src/cli/index.ts"
  },
  "scripts": {
    "api": "bun --hot src/api/server.ts",
    "frontend": "bunx vite src/dashboard --host localhost --port 5173",
    "dev": "bun run src/api/server.ts",
    "build": "bun build src/dashboard/frontend.tsx --outdir dist",
    "test": "bun test",
    "bot": "bun run src/bot/server.ts",
    "mcp": "bun run src/mcp/server.ts",
    "action": "bun run src/cli/index.ts scan . --sarif"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "zod": "^3.22.4",
    "axios": "^1.6.5",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.10",
    "cli-table3": "^0.6.3",
    "ora": "^8.0.1",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
